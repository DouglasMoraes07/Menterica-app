# ============================================
# BANCO DE DADOS
# ============================================
DATABASE_URL=mysql://usuario:senha@localhost:3306/menterica

# ============================================
# AUTENTICAÇÃO (JWT próprio, sem Manus OAuth)
# ============================================
JWT_SECRET=gere-uma-string-aleatoria-de-64-caracteres-aqui

# ============================================
# OPENAI (substitui o LLM do Manus)
# ============================================
OPENAI_API_KEY=sk-proj-sua-chave-aqui

# ============================================
# STRIPE (pagamentos)
# ============================================
STRIPE_SECRET_KEY=sk_test_sua-chave-aqui
STRIPE_WEBHOOK_SECRET=whsec_sua-chave-aqui
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_sua-chave-aqui

# ============================================
# HOTMART (webhooks)
# ============================================
HOTMART_TOKEN=seu-token-hotmart

# ============================================
# STORAGE (S3 / MinIO / Cloudflare R2)
# ============================================
S3_BUCKET=menterica-files
S3_REGION=us-east-1
S3_ACCESS_KEY=sua-access-key
S3_SECRET_KEY=sua-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# ============================================
# APP CONFIG
# ============================================
NODE_ENV=production
PORT=3000
APP_URL=https://menterica.click
VITE_APP_TITLE=MenteRica - Bem-Estar Financeiro e Emocional
